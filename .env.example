# Copy to `.env` and fill in for local development:  cp .env.example .env
# NEVER commit real secrets. In CI these are provided as GitHub Secrets
# (see .github/workflows/ingest.yml). Names here map 1:1 to those secrets.
#
# These vars are consumed by the Python ingestion pipeline (/ingestion).
# The web dashboard (/web) does NOT use these — it reads D1 through the
# Cloudflare Worker binding `DB` (configured in web/wrangler.jsonc).

# ---- OpenAI (field extraction) ----
OPENAI_API_KEY=

# ---- Scraping / fetching ----
FIRECRAWL_API_KEY=
SCRAPEDO_API_KEY=

# ---- Cloudflare D1 (ingestion write target, via D1 HTTP API) ----
CF_ACCOUNT_ID=
CF_D1_DATABASE_ID=
CF_API_TOKEN=

# ---- Optional: Screener.in login ----
SCREENER_EMAIL=
SCREENER_PASSWORD=

# ---- Optional: internal token ----
MUNS_TOKEN=
