{
  "name": "orderbook-web",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-company order-book dashboard for Indian listed companies (Next.js on Cloudflare Workers).",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "db:migrate:local": "wrangler d1 migrations apply orderbook --local",
    "db:migrate:remote": "wrangler d1 migrations apply orderbook --remote",
    "db:seed:local": "wrangler d1 execute orderbook --local --file=../db/seed.sql"
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.2",
    "wrangler": "^4.107.0"
  }
}
